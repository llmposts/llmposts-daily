---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import DayBlock from "../../components/DayBlock.astro";
import PosterButton from "../../components/PosterButton.astro";
import { dayGroup, getAvailableDateKeys } from "../../lib/data";
import { formatCnLongDate, weekdayCn } from "../../lib/dates";

export async function getStaticPaths() {
  const keys = getAvailableDateKeys();
  return keys.map((date, i) => ({
    params: { date },
    props: {
      date,
      prev: keys[i + 1] ?? null, // older (列表是新→旧)
      next: keys[i - 1] ?? null, // newer
    },
  }));
}

interface Props {
  date: string;
  prev: string | null;
  next: string | null;
}

const { date, prev, next } = Astro.props;
const day = dayGroup(date);
const longDate = formatCnLongDate(date);
const pageTitle = `LLM 日报 · ${date}`;
const desc = `${longDate} · 共 ${day.posts.length} 篇 AI 要闻汇总`;
const siteOrigin = Astro.site?.toString() ?? "https://archive.llmposts.com";
const posterData = {
  dateKey: day.key,
  formalDate: formatCnLongDate(day.key),
  weekday: weekdayCn(day.key),
  vol: day.key.replace(/-/g, "."),
  posts: day.posts.map((p) => ({
    title: p.title,
    summary: p.summary,
    link: p.link,
    category: p.category,
  })),
  categoryCounts: day.categories.map((c) => ({
    category: c.category,
    count: c.posts.length,
  })),
  url: `${siteOrigin.replace(/\/$/, "")}/daily/${day.key}/`,
};
---

<BaseLayout title={pageTitle} description={desc}>
  <SiteHeader active="all" />
  <main>
    <div class="page-actions">
      <span class="action-hint">为 {longDate} 生成可分享海报</span>
      <PosterButton data={posterData} />
    </div>
    <DayBlock day={day} isFirst={true} />
    <nav class="prev-next" aria-label="前后日导航">
      {
        prev ? (
          <a href={`/daily/${prev}/`} class="link prev">
            ← {prev}
          </a>
        ) : (
          <span class="link disabled">已是最早</span>
        )
      }
      <a href="/" class="link home">回到首页</a>
      {
        next ? (
          <a href={`/daily/${next}/`} class="link next">
            {next} →
          </a>
        ) : (
          <span class="link disabled">已是最新</span>
        )
      }
    </nav>
  </main>
  <footer class="site-footer">
    <div class="footer-meta">
      <span>LLM 日报 · 大模型邮报每日要闻汇总 · 仅摘要,完整文章在官网</span>
      <a class="right" href="https://llmposts.com">→ llmposts.com</a>
    </div>
  </footer>
</BaseLayout>

<style>
  main {
    padding: 8px 0 64px;
  }
  .page-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
    padding: 20px 0 8px;
  }
  .action-hint {
    font-size: 13px;
    color: var(--muted);
  }
  @media (max-width: 760px) {
    .page-actions { justify-content: space-between; }
    .action-hint { font-size: 12px; }
  }
  .prev-next {
    margin-top: 80px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 16px;
    align-items: center;
    font-size: 14px;
    font-weight: 500;
  }
  .link {
    color: var(--text);
    text-decoration: none;
    padding: 9px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    transition: background-color 0.15s, border-color 0.15s;
    text-align: center;
  }
  .link:hover {
    background: var(--chip-bg);
    border-color: var(--muted);
  }
  .link.disabled {
    color: var(--muted);
    opacity: 0.5;
    cursor: default;
  }
  .link.disabled:hover {
    background: var(--surface);
    border-color: var(--border);
  }
  .prev {
    justify-self: start;
    font-feature-settings: "tnum" 1;
  }
  .next {
    justify-self: end;
    font-feature-settings: "tnum" 1;
  }
  .home {
    color: var(--muted);
    border-color: transparent;
    background: transparent;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 96px;
    padding: 56px 0 72px;
  }
  .footer-meta {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 14px;
    color: var(--muted);
  }
  .footer-meta a {
    color: var(--muted);
    text-decoration: none;
  }
  .footer-meta a.right {
    color: var(--link);
    font-weight: 500;
  }
  .footer-meta a:hover {
    color: var(--text);
  }
  .footer-meta a.right:hover {
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .prev-next {
      grid-template-columns: 1fr 1fr;
    }
    .home {
      grid-column: 1 / -1;
      order: -1;
    }
  }
</style>
