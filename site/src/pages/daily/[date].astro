---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import DayBlock from "../../components/DayBlock.astro";
import PosterButton from "../../components/PosterButton.astro";
import { dayGroup, getAvailableDateKeys } from "../../lib/data";
import {
  formatCnLongDate,
  weekdayCn,
  relativeLabel,
} from "../../lib/dates";

export async function getStaticPaths() {
  const keys = getAvailableDateKeys();
  return keys.map((date, i) => ({
    params: { date },
    props: {
      date,
      prev: keys[i + 1] ?? null, // older (列表是新→旧)
      next: keys[i - 1] ?? null, // newer
      issueNumber: keys.length - i,
    },
  }));
}

interface Props {
  date: string;
  prev: string | null;
  next: string | null;
  issueNumber: number;
}

const { date, prev, next, issueNumber } = Astro.props;
const day = dayGroup(date);
const longDate = formatCnLongDate(date);
const wk = weekdayCn(date);
const rel = relativeLabel(date);
const [, m, d] = date.split("-");
const edition = `VOL.${date.slice(2, 4)}`;
const readTime = day.posts.length * 4;
const pageTitle = `LLM 日报 · ${date}`;
const desc = `${longDate} · 共 ${day.posts.length} 篇 AI 要闻汇总`;
const siteOrigin = Astro.site?.toString() ?? "https://archive.llmposts.com";
const posterData = {
  dateKey: day.key,
  formalDate: formatCnLongDate(day.key),
  weekday: weekdayCn(day.key),
  vol: day.key.replace(/-/g, "."),
  posts: day.posts.map((p) => ({
    title: p.title,
    summary: p.summary,
    link: p.link,
    category: p.category,
  })),
  categoryCounts: day.categories.map((c) => ({
    category: c.category,
    count: c.posts.length,
  })),
  url: `${siteOrigin.replace(/\/$/, "")}/daily/${day.key}/`,
};
---

<BaseLayout title={pageTitle} description={desc}>
  <SiteHeader active="all" />
  <main>
    <header class="issue-mast">
      <div class="issue-row">
        {edition} <span class="dot">·</span> #{issueNumber}
        <span class="dot">·</span> {longDate} <span class="dot">·</span> {wk}
        {rel && <><span class="dot">·</span> <span class="rel">{rel}</span></>}
      </div>
      <h1 class="issue-title">
        <span class="num">{parseInt(m, 10)}.{parseInt(d, 10)}</span> 日邮报
      </h1>
      <p class="issue-sub">
        本期 <strong>{day.posts.length}</strong> 篇要闻 · 约 <strong>{readTime}</strong> 分钟阅读 · 覆盖 <strong>{day.categories.length}</strong> 类
      </p>
      <div class="issue-actions">
        <PosterButton data={posterData} />
        <a class="btn" href="/">回到首页</a>
      </div>
    </header>

    <DayBlock day={day} isFirst={true} />

    <nav class="prev-next" aria-label="前后日导航">
      {
        prev ? (
          <a href={`/daily/${prev}/`} class="pn-card">
            <div class="pn-label">← 上一期</div>
            <div class="pn-date">{prev}</div>
          </a>
        ) : (
          <span class="pn-card disabled">
            <div class="pn-label">上一期</div>
            <div class="pn-date">已是最早</div>
          </span>
        )
      }
      {
        next ? (
          <a href={`/daily/${next}/`} class="pn-card right">
            <div class="pn-label">下一期 →</div>
            <div class="pn-date">{next}</div>
          </a>
        ) : (
          <span class="pn-card right disabled">
            <div class="pn-label">下一期</div>
            <div class="pn-date">已是最新</div>
          </span>
        )
      }
    </nav>
  </main>

  <footer class="site-footer">
    <div class="foot-bot">
      <span>© {new Date().getFullYear()} LLM 日报(大模型日报) · 仅作存档</span>
      <a class="right" href="https://llmposts.com">→ llmposts.com</a>
    </div>
  </footer>
</BaseLayout>

<style>
  main {
    padding: 0 0 64px;
  }
  .issue-mast {
    padding: 48px 0 36px;
    text-align: center;
    border-bottom: 1px solid var(--text);
    margin-bottom: 8px;
  }
  .issue-row {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 18px;
  }
  .issue-row .dot {
    color: var(--accent);
    margin: 0 8px;
  }
  .issue-row .rel {
    color: var(--accent);
  }
  .issue-title {
    font-family: var(--font-serif);
    font-size: 64px;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 0.98;
    margin: 0;
    color: var(--text);
  }
  .issue-title .num {
    color: var(--accent);
    font-style: italic;
    font-weight: 500;
    font-feature-settings: "tnum" 1;
  }
  .issue-sub {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--text-soft);
    margin: 18px auto 0;
    max-width: 540px;
    line-height: 1.6;
  }
  .issue-sub strong {
    font-style: normal;
    color: var(--text);
    font-weight: 600;
  }
  .issue-actions {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  .prev-next {
    margin-top: 80px;
    padding-top: 36px;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .pn-card {
    display: block;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    background: var(--surface);
    transition: border-color 0.15s, background-color 0.15s;
  }
  .pn-card:hover {
    border-color: var(--border-strong);
    background: var(--chip-bg);
  }
  .pn-card.right {
    text-align: right;
  }
  .pn-card.disabled {
    opacity: 0.5;
    pointer-events: none;
  }
  .pn-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }
  .pn-date {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    font-feature-settings: "tnum" 1;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 96px;
    padding: 32px 0 60px;
  }
  .foot-bot {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 13px;
    letter-spacing: 0.01em;
    color: var(--muted);
  }
  .foot-bot a {
    color: var(--muted);
    text-decoration: none;
  }
  .foot-bot a.right {
    color: var(--accent);
    font-weight: 500;
  }
  .foot-bot a:hover {
    color: var(--text);
  }

  @media (max-width: 760px) {
    .issue-title {
      font-size: 44px;
    }
    .prev-next {
      grid-template-columns: 1fr;
    }
    .pn-card.right {
      text-align: left;
    }
  }
</style>
