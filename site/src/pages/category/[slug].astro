---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import DayBlock from "../../components/DayBlock.astro";
import { CATEGORIES, CATEGORY_BY_SLUG } from "../../lib/categories";
import { categoryDayGroups } from "../../lib/data";

export async function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = CATEGORY_BY_SLUG.get(slug!);

if (!cat) {
  return Astro.redirect("/404");
}

const days = categoryDayGroups(cat.zh);
const total = days.reduce((n, d) => n + d.posts.length, 0);
const pageTitle = `LLM 日报 · ${cat.zh}`;
const desc = `${cat.zh} 分类下全部 AI 要闻 · 共 ${total} 篇`;
---

<BaseLayout title={pageTitle} description={desc}>
  <SiteHeader active={cat.slug} />
  <main>
    <header class="cat-hero">
      <div class="cat-eyebrow">─── 分类 / Category</div>
      <h1 class="cat-h1">
        <span class="dot" style={`background: var(${cat.colorVar})`}></span>
        {cat.zh}
        <span class="cat-en">{cat.en}</span>
      </h1>
      <p class="cat-meta">
        共 <strong>{total}</strong> 篇 · 覆盖 <strong>{days.length}</strong> 天
      </p>
    </header>

    {days.map((d, i) => <DayBlock day={d} isFirst={i === 0} />)}

    {
      days.length === 0 && (
        <p class="empty">该分类暂无内容。</p>
      )
    }

    <nav class="back">
      <a href="/">← 回到首页</a>
    </nav>
  </main>

  <footer class="site-footer">
    <div class="foot-bot">
      <span>© {new Date().getFullYear()} LLM 日报(大模型日报) · 仅作存档</span>
      <a class="right" href="https://llmposts.com">→ llmposts.com</a>
    </div>
  </footer>
</BaseLayout>

<style>
  main {
    padding: 0 0 64px;
  }
  .cat-hero {
    padding: 40px 0 28px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }
  .cat-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 12px;
  }
  .cat-h1 {
    margin: 0 0 14px;
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .cat-h1 .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: inline-block;
  }
  .cat-en {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    align-self: center;
    margin-left: 6px;
  }
  .cat-meta {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--text-soft);
    margin: 0;
  }
  .cat-meta strong {
    font-style: normal;
    color: var(--text);
    font-feature-settings: "tnum" 1;
  }

  .empty {
    margin: 80px 0;
    text-align: center;
    color: var(--muted);
  }
  .back {
    margin-top: 80px;
    text-align: center;
  }
  .back a {
    display: inline-block;
    padding: 10px 26px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    color: var(--text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    background: var(--surface);
    transition: background-color 0.15s, border-color 0.15s;
  }
  .back a:hover {
    background: var(--chip-bg);
    border-color: var(--muted);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 96px;
    padding: 32px 0 60px;
  }
  .foot-bot {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 13px;
    letter-spacing: 0.01em;
    color: var(--muted);
  }
  .foot-bot a {
    color: var(--muted);
    text-decoration: none;
  }
  .foot-bot a.right {
    color: var(--accent);
    font-weight: 500;
  }
  .foot-bot a:hover {
    color: var(--text);
  }

  @media (max-width: 760px) {
    .cat-h1 {
      font-size: 36px;
    }
  }
</style>
