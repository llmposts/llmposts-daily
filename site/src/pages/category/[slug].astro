---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import DayBlock from "../../components/DayBlock.astro";
import { CATEGORIES, CATEGORY_BY_SLUG } from "../../lib/categories";
import { categoryDayGroups } from "../../lib/data";

export async function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = CATEGORY_BY_SLUG.get(slug!);

if (!cat) {
  return Astro.redirect("/404");
}

const days = categoryDayGroups(cat.zh);
const total = days.reduce((n, d) => n + d.posts.length, 0);
const pageTitle = `LLM 日报 · ${cat.zh}`;
const desc = `${cat.zh} 分类下全部 AI 要闻 · 共 ${total} 篇`;
---

<BaseLayout title={pageTitle} description={desc}>
  <SiteHeader active={cat.slug} />
  <main>
    <section class="cat-hero">
      <div class="cat-eyebrow">分类</div>
      <h1 class="cat-h1">
        <span class="dot" style={`background: var(${cat.colorVar})`}></span>
        {cat.zh}
      </h1>
      <div class="cat-meta">
        共 {total} 篇 · 覆盖 {days.length} 天
      </div>
    </section>

    {days.map((d, i) => <DayBlock day={d} isFirst={i === 0} />)}

    {
      days.length === 0 && (
        <p class="empty">该分类暂无内容。</p>
      )
    }

    <nav class="back">
      <a href="/">← 回到首页</a>
    </nav>
  </main>
  <footer class="site-footer">
    <div class="footer-meta">
      <span>LLM 日报 · 大模型邮报每日要闻汇总 · 仅摘要,完整文章在官网</span>
      <a class="right" href="https://llmposts.com">→ llmposts.com</a>
    </div>
  </footer>
</BaseLayout>

<style>
  main {
    padding: 8px 0 64px;
  }
  .cat-hero {
    padding: 40px 0 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }
  .cat-eyebrow {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 10px;
    font-weight: 600;
  }
  .cat-h1 {
    margin: 0 0 10px;
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .cat-h1 .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .cat-meta {
    font-size: 14px;
    color: var(--muted);
  }
  .empty {
    margin: 80px 0;
    text-align: center;
    color: var(--muted);
  }
  .back {
    margin-top: 80px;
    text-align: center;
  }
  .back a {
    display: inline-block;
    padding: 9px 20px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    background: var(--surface);
    transition: background-color 0.15s, border-color 0.15s;
  }
  .back a:hover {
    background: var(--chip-bg);
    border-color: var(--muted);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 96px;
    padding: 56px 0 72px;
  }
  .footer-meta {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 14px;
    color: var(--muted);
  }
  .footer-meta a {
    color: var(--muted);
    text-decoration: none;
  }
  .footer-meta a.right {
    color: var(--link);
    font-weight: 500;
  }
  .footer-meta a:hover {
    color: var(--text);
  }
  .footer-meta a.right:hover {
    text-decoration: underline;
  }
</style>
