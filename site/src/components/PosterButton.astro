---
import type { PosterData } from "../scripts/poster";

interface Props {
  data: PosterData;
}

const { data } = Astro.props;
const dataId = `poster-data-${data.dateKey}`;
---

<button
  type="button"
  class="poster-trigger"
  data-poster-data-id={dataId}
  aria-label={`生成 ${data.formalDate} 海报`}
>
  生成海报
</button>

<script
  is:inline
  type="application/json"
  id={dataId}
  set:html={JSON.stringify(data)}
/>

<script>
  import {
    renderPoster,
    canvasToBlob,
    type PosterData,
    type PosterTheme,
  } from "../scripts/poster";

  let currentBlob: Blob | null = null;
  let currentUrl: string | null = null;
  let currentData: PosterData | null = null;
  let currentTheme: PosterTheme = "light";

  function ensureModal(): HTMLElement {
    let modal = document.getElementById("lp-poster-modal");
    if (modal) return modal;
    modal = document.createElement("div");
    modal.id = "lp-poster-modal";
    modal.className = "lp-poster-modal";
    modal.hidden = true;
    modal.innerHTML = `
      <div class="lp-poster-modal__backdrop" data-poster-close></div>
      <div class="lp-poster-modal__panel" role="dialog" aria-modal="true" aria-label="海报预览">
        <button type="button" class="lp-poster-modal__close" data-poster-close aria-label="关闭">✕</button>
        <div class="lp-poster-modal__preview">
          <img alt="海报预览" />
        </div>
        <div class="lp-poster-modal__actions">
          <button type="button" class="lp-poster-modal__btn" data-poster-theme>切换深浅</button>
          <button type="button" class="lp-poster-modal__btn" data-poster-copy>复制图片</button>
          <a class="lp-poster-modal__btn lp-poster-modal__btn--primary" data-poster-download download="">下载图片</a>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    return modal;
  }

  function disposeCurrent(): void {
    if (currentUrl) {
      URL.revokeObjectURL(currentUrl);
      currentUrl = null;
    }
    currentBlob = null;
  }

  function applyCurrent(): void {
    if (!currentBlob || !currentUrl || !currentData) return;
    const modal = ensureModal();
    const img = modal.querySelector("img") as HTMLImageElement;
    const dl = modal.querySelector(
      "[data-poster-download]",
    ) as HTMLAnchorElement;
    img.src = currentUrl;
    dl.href = currentUrl;
    dl.download = `llm-daily-${currentData.dateKey}-${currentTheme}.png`;
  }

  async function generate(theme: PosterTheme): Promise<void> {
    if (!currentData) return;
    const canvas = await renderPoster(currentData, { theme, showQr: true });
    const blob = await canvasToBlob(canvas);
    disposeCurrent();
    if (blob) {
      currentBlob = blob;
      currentUrl = URL.createObjectURL(blob);
      applyCurrent();
    }
  }

  function showModal(): void {
    const modal = ensureModal();
    modal.hidden = false;
    document.documentElement.classList.add("lp-poster-open");
  }

  function hideModal(): void {
    const modal = document.getElementById("lp-poster-modal");
    if (modal) {
      modal.hidden = true;
      document.documentElement.classList.remove("lp-poster-open");
    }
  }

  function getInitialTheme(): PosterTheme {
    const cur = document.documentElement.getAttribute("data-theme");
    if (cur === "dark") return "dark";
    if (cur === "light") return "light";
    if (window.matchMedia?.("(prefers-color-scheme: dark)").matches) return "dark";
    return "light";
  }

  function bindOnce(): void {
    const k = "__lpPosterBound";
    if ((window as unknown as Record<string, unknown>)[k]) return;
    (window as unknown as Record<string, unknown>)[k] = true;

    document.addEventListener("click", async (e) => {
      const target = e.target as HTMLElement;
      if (!target) return;

      const trigger = target.closest("[data-poster-data-id]") as HTMLButtonElement | null;
      if (trigger) {
        const dataId = trigger.dataset.posterDataId;
        if (!dataId) return;
        const script = document.getElementById(dataId);
        if (!script) return;
        try {
          currentData = JSON.parse(script.textContent || "") as PosterData;
        } catch {
          return;
        }
        currentTheme = getInitialTheme();
        trigger.disabled = true;
        const orig = trigger.textContent;
        trigger.textContent = "生成中…";
        try {
          await generate(currentTheme);
          showModal();
        } catch (err) {
          alert("海报生成失败,请刷新后重试。");
        } finally {
          trigger.disabled = false;
          trigger.textContent = orig;
        }
        return;
      }

      if (target.closest("[data-poster-close]")) {
        hideModal();
        return;
      }
      if (target.closest("[data-poster-theme]")) {
        currentTheme = currentTheme === "light" ? "dark" : "light";
        await generate(currentTheme);
        return;
      }
      const copyBtn = target.closest("[data-poster-copy]") as HTMLButtonElement | null;
      if (copyBtn) {
        if (!currentBlob || !navigator.clipboard || !window.ClipboardItem) {
          copyBtn.textContent = "请下载";
          return;
        }
        const orig = copyBtn.textContent;
        try {
          await navigator.clipboard.write([
            new ClipboardItem({ "image/png": currentBlob }),
          ]);
          copyBtn.textContent = "已复制";
        } catch {
          copyBtn.textContent = "复制失败";
        }
        setTimeout(() => {
          copyBtn.textContent = orig;
        }, 1400);
        return;
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") hideModal();
    });
  }

  bindOnce();
</script>

<style>
  .poster-trigger {
    font-family: var(--font-sans);
    font-size: 13.5px;
    font-weight: 500;
    padding: 8px 16px;
    border: 1px solid var(--border-strong);
    border-radius: var(--r-sm);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: background-color 0.15s, border-color 0.15s;
  }
  .poster-trigger:hover {
    background: var(--chip-bg);
  }
  .poster-trigger:disabled {
    opacity: 0.55;
    cursor: wait;
  }
</style>

<style is:global>
  html.lp-poster-open {
    overflow: hidden;
  }
  .lp-poster-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
  }
  .lp-poster-modal[hidden] {
    display: none;
  }
  .lp-poster-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  .lp-poster-modal__panel {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    max-width: 600px;
    width: 100%;
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
  .lp-poster-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    font-size: 14px;
    font-family: inherit;
    z-index: 1;
  }
  .lp-poster-modal__close:hover {
    background: rgba(0, 0, 0, 0.6);
  }
  .lp-poster-modal__preview {
    flex: 1;
    overflow: auto;
    padding: 20px;
    background: var(--surface);
  }
  .lp-poster-modal__preview img {
    display: block;
    width: 100%;
    height: auto;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }
  .lp-poster-modal__actions {
    display: flex;
    gap: 8px;
    padding: 14px 16px;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .lp-poster-modal__btn {
    font-family: inherit;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .lp-poster-modal__btn:hover {
    background: var(--chip-bg);
    border-color: var(--muted);
  }
  .lp-poster-modal__btn--primary {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
    font-weight: 600;
  }
  .lp-poster-modal__btn--primary:hover {
    background: var(--text-soft);
    border-color: var(--text-soft);
  }
</style>
