---
import ThemeToggle from "./ThemeToggle.astro";
import { CATEGORIES } from "../lib/categories";

interface Props {
  /** 当前激活的分类 slug,'all' 或 category slug */
  active?: string;
}

const { active = "all" } = Astro.props;
---

<nav class="nav" aria-label="主导航">
  <a class="nav-brand" href="/">LLM<span class="em">·</span>日报</a>

  <div class="nav-chips" aria-label="分类筛选">
    <a class={`chip${active === "all" ? " active" : ""}`} href="/">全部</a>
    {
      CATEGORIES.map((c) => (
        <a
          class={`chip${active === c.slug ? " active" : ""}`}
          href={`/category/${c.slug}/`}
          style={`--c: var(${c.colorVar})`}
          title={c.zh}
        >
          <span class="dot" />
          {c.short}
        </a>
      ))
    }
  </div>

  <div class="nav-actions">
    <button
      class="search-btn"
      type="button"
      id="lp-search-trigger"
      title="搜索本页要闻 (⌘K)"
      aria-label="搜索"
    >
      <span class="ico" aria-hidden="true">⌕</span>
      <span class="lbl">搜索本页要闻</span>
      <span class="kbd" aria-hidden="true">⌘K</span>
    </button>
    <ThemeToggle />
    <a class="text-btn" href="/rss.xml" title="RSS 订阅">RSS</a>
    <a class="sub-btn" href="https://llmposts.com" title="访问主站订阅">
      订阅 <span class="arr" aria-hidden="true">→</span>
    </a>
  </div>
</nav>

<script is:inline>
  (() => {
    if (window.__lpSearchBound) return;
    window.__lpSearchBound = true;

    const trigger = document.getElementById("lp-search-trigger");
    if (!trigger) return;

    function ensureModal() {
      let modal = document.getElementById("lp-search-modal");
      if (modal) return modal;
      modal = document.createElement("div");
      modal.id = "lp-search-modal";
      modal.className = "lp-search-modal";
      modal.hidden = true;
      modal.innerHTML = [
        '<div class="lp-search-modal__backdrop" data-search-close></div>',
        '<div class="lp-search-modal__panel" role="dialog" aria-modal="true" aria-label="搜索">',
        '  <div class="lp-search-modal__bar">',
        '    <span class="lp-search-modal__ico" aria-hidden="true">⌕</span>',
        '    <input class="lp-search-modal__input" type="text" placeholder="搜索本页要闻、标题、摘要…" autocomplete="off" />',
        '    <kbd class="lp-search-modal__kbd">ESC</kbd>',
        '  </div>',
        '  <div class="lp-search-modal__status" data-search-status></div>',
        '</div>',
      ].join("");
      document.body.appendChild(modal);
      return modal;
    }

    function getEntries() {
      return Array.from(document.querySelectorAll("main .entry"));
    }
    function getDays() {
      return Array.from(document.querySelectorAll("main .day"));
    }
    // Page chrome that should hide while a search filter is active,
    // so the result list isn't pushed below the fold.
    var CHROME_SELECTOR =
      ".mast, .hero, .section-rule, .older, .prev-next, .issue-mast, .cat-hero";
    function getChrome() {
      return Array.from(document.querySelectorAll(CHROME_SELECTOR));
    }

    function highlight(el, query) {
      const titleEl = el.querySelector(".entry-title a");
      const sumEl = el.querySelector(".entry-summary");
      [titleEl, sumEl].forEach((node) => {
        if (!node) return;
        if (!node.dataset.origText) node.dataset.origText = node.textContent;
        const text = node.dataset.origText;
        if (!query) {
          node.textContent = text;
          return;
        }
        const idx = text.toLowerCase().indexOf(query.toLowerCase());
        if (idx < 0) {
          node.textContent = text;
          return;
        }
        node.innerHTML = "";
        node.appendChild(document.createTextNode(text.slice(0, idx)));
        const mark = document.createElement("mark");
        mark.className = "lp-search-hit";
        mark.textContent = text.slice(idx, idx + query.length);
        node.appendChild(mark);
        node.appendChild(document.createTextNode(text.slice(idx + query.length)));
      });
    }

    function applyFilter(query) {
      const q = query.trim().toLowerCase();
      const entries = getEntries();
      let visible = 0;
      let firstHit = null;
      entries.forEach((el) => {
        if (!q) {
          el.style.display = "";
          highlight(el, "");
          visible += 1;
          return;
        }
        const hay = (el.textContent || "").toLowerCase();
        const match = hay.indexOf(q) >= 0;
        el.style.display = match ? "" : "none";
        highlight(el, match ? query.trim() : "");
        if (match) {
          visible += 1;
          if (!firstHit) firstHit = el;
        }
      });
      // Hide day blocks whose entries are all filtered out
      getDays().forEach((day) => {
        const dayHasMatch = !!day.querySelector(".entry:not([data-hidden])");
        let anyVisible = false;
        day.querySelectorAll(".entry").forEach((e) => {
          if (e.style.display !== "none") anyVisible = true;
        });
        day.style.display = q ? (anyVisible ? "" : "none") : "";
      });
      // Hide hero/masthead/section-header while searching, so the result
      // list sits at the top of the viewport.
      getChrome().forEach((el) => {
        el.style.display = q ? "none" : "";
      });
      // Bring the first hit into view (so the user doesn't have to scroll
      // through hidden space to find results).
      if (q && firstHit) {
        firstHit.scrollIntoView({ block: "center", behavior: "auto" });
      } else if (!q) {
        window.scrollTo({ top: 0, behavior: "auto" });
      }
      return visible;
    }

    function clearFilter() {
      getEntries().forEach((el) => {
        el.style.display = "";
        highlight(el, "");
      });
      getDays().forEach((el) => {
        el.style.display = "";
      });
      getChrome().forEach((el) => {
        el.style.display = "";
      });
    }

    function openModal() {
      const modal = ensureModal();
      modal.hidden = false;
      const input = modal.querySelector(".lp-search-modal__input");
      setTimeout(() => input && input.focus(), 0);
    }

    function closeModal() {
      const modal = document.getElementById("lp-search-modal");
      if (modal) modal.hidden = true;
      clearFilter();
    }

    function isOpen() {
      const modal = document.getElementById("lp-search-modal");
      return !!modal && !modal.hidden;
    }

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      openModal();
    });

    document.addEventListener("click", (e) => {
      if (!isOpen()) return;
      const t = e.target;
      if (!t || !t.closest) return;
      if (t.closest("[data-search-close]")) {
        closeModal();
        return;
      }
      // Click anywhere outside the panel → close (filter clears too)
      if (!t.closest(".lp-search-modal__panel") && !t.closest("#lp-search-trigger")) {
        closeModal();
      }
    });

    document.addEventListener("input", (e) => {
      const t = e.target;
      if (!t || !t.classList || !t.classList.contains("lp-search-modal__input")) return;
      const visible = applyFilter(t.value);
      const status = document.querySelector("[data-search-status]");
      if (!status) return;
      const q = t.value.trim();
      if (!q) status.textContent = "输入关键词以筛选本页要闻 · 支持中英文。";
      else status.textContent = visible
        ? "命中 " + visible + " 条 · 按 ESC 关闭并清除筛选"
        : "没有匹配项 · 试试更短的关键词";
    });

    document.addEventListener("keydown", (e) => {
      const isMac = navigator.platform.toLowerCase().includes("mac");
      const meta = isMac ? e.metaKey : e.ctrlKey;
      if (meta && (e.key === "k" || e.key === "K")) {
        e.preventDefault();
        openModal();
        return;
      }
      const modal = document.getElementById("lp-search-modal");
      const open = modal && !modal.hidden;
      if (open && e.key === "Escape") {
        e.preventDefault();
        closeModal();
      }
      if (!open && e.key === "/" && document.activeElement === document.body) {
        e.preventDefault();
        openModal();
      }
    });
  })();
</script>

<style is:global>
  /* Search panel — anchored top-center, no opaque backdrop so the
     filtered page stays visible behind it. */
  .lp-search-modal {
    position: fixed;
    top: 16px;
    left: 0;
    right: 0;
    z-index: 60;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 0 16px;
    pointer-events: none;
  }
  .lp-search-modal[hidden] {
    display: none;
  }
  .lp-search-modal__backdrop {
    /* Tiny invisible click target above the page; the panel is small
       enough that scrolling/clicking elsewhere on the page works as
       implicit dismiss. We avoid covering the page so filter results
       remain visible while typing. */
    display: none;
  }
  .lp-search-modal__panel {
    position: relative;
    width: 100%;
    max-width: 560px;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
    overflow: hidden;
    pointer-events: auto;
  }
  .lp-search-modal__bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }
  .lp-search-modal__ico {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--muted);
  }
  .lp-search-modal__input {
    flex: 1;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.4;
  }
  .lp-search-modal__input::placeholder {
    color: var(--muted);
  }
  .lp-search-modal__kbd {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    background: var(--chip-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-soft);
  }
  .lp-search-modal__status {
    padding: 12px 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .lp-search-hit {
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 2px;
    padding: 0 2px;
  }
</style>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in oklab, var(--bg) 90%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 12px 32px;
    margin: 0 -32px;
  }
  .nav-brand {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--text);
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-brand .em {
    color: var(--accent);
    font-style: italic;
    font-weight: 500;
    margin: 0 1px;
  }

  .nav-chips {
    display: flex;
    gap: 4px;
    flex: 1;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .nav-chips::-webkit-scrollbar {
    display: none;
  }
  .chip {
    font-size: 13px;
    font-weight: 500;
    color: var(--chip-text);
    background: transparent;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid transparent;
    white-space: nowrap;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: background-color 0.15s, color 0.15s;
  }
  .chip:hover {
    background: var(--chip-bg);
    color: var(--text);
  }
  .chip.active {
    background: var(--text);
    color: var(--bg);
    font-weight: 600;
  }
  .chip .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c, var(--muted));
    display: inline-block;
    flex-shrink: 0;
  }

  .nav-actions {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-shrink: 0;
  }

  /* Search trigger — pill with icon + label + kbd */
  .search-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 32px;
    padding: 0 6px 0 12px;
    background: var(--chip-bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-soft);
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    min-width: 220px;
    transition: border-color 0.15s, color 0.15s;
  }
  .search-btn:hover {
    border-color: var(--border-strong);
    color: var(--text);
  }
  .search-btn .ico {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--muted);
  }
  .search-btn .lbl {
    flex: 1;
    text-align: left;
    color: var(--muted);
  }
  .search-btn .kbd {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--text-soft);
  }

  /* Compact mono label (RSS) */
  .text-btn {
    height: 32px;
    padding: 0 10px;
    display: inline-flex;
    align-items: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    color: var(--text-soft);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .text-btn:hover {
    background: var(--chip-bg);
    color: var(--text);
  }

  /* Subscribe — primary CTA in nav */
  .sub-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 32px;
    padding: 0 14px;
    background: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.15s, border-color 0.15s;
  }
  .sub-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .sub-btn .arr {
    font-family: var(--font-mono);
    font-size: 12px;
  }

  @media (max-width: 900px) {
    .search-btn {
      min-width: 0;
      padding: 0 10px;
    }
    .search-btn .lbl {
      display: none;
    }
    .search-btn .kbd {
      display: none;
    }
  }
  @media (max-width: 760px) {
    .nav {
      padding: 12px 18px;
      margin: 0 -18px;
      gap: 12px;
    }
    .nav-chips {
      order: 3;
      flex-basis: 100%;
      margin-top: 6px;
    }
    .text-btn {
      display: none;
    }
  }
</style>
