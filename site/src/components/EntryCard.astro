---
import type { Post } from "../lib/data";
import { CATEGORY_BY_ZH, categoryColorVar } from "../lib/categories";

interface Props {
  post: Post;
  index: number;
}

const { post, index } = Astro.props;
const num = String(index).padStart(2, "0");
const cat = CATEGORY_BY_ZH.get(post.category);
const catShort = cat?.short ?? post.category;
const colorVar = categoryColorVar(post.category);

// 从原文链接里抽个简短的域名作为来源标签
let source = "";
try {
  const host = new URL(post.link).hostname.replace(/^www\./, "");
  source = host;
} catch {
  source = "";
}
---

<article class="entry" style={`--c: var(${colorVar})`}>
  <div class="entry-num">{num}</div>
  <div class="entry-body">
    <h3 class="entry-title">
      <a href={post.link} target="_blank" rel="noopener">{post.title}</a>
    </h3>
    <p class="entry-summary">{post.summary}</p>
    <div class="entry-foot">
      <span class="meta">
        <span class="cat">{catShort}</span>
        {source && <>
          <span class="sep">/</span>
          <span class="src">{source}</span>
        </>}
      </span>
      <a class="read" href={post.link} target="_blank" rel="noopener">
        阅读原文 <span class="arr" aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</article>

<style>
  .entry {
    display: grid;
    grid-template-columns: 36px 1fr;
    column-gap: 18px;
    padding: 24px 0;
    border-top: 1px solid var(--border);
    position: relative;
  }
  .entry:first-of-type {
    border-top: none;
    padding-top: 4px;
  }
  .entry-num {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--c, var(--muted));
    font-weight: 600;
    padding-top: 6px;
    font-feature-settings: "tnum" 1;
  }
  .entry-body {
    min-width: 0;
  }
  .entry-title {
    margin: 0 0 10px;
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.32;
    letter-spacing: -0.01em;
  }
  .entry-title a {
    color: var(--text);
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.2s ease;
  }
  .entry-title a:hover {
    background-size: 100% 1px;
  }
  .entry-summary {
    margin: 0 0 12px;
    color: var(--text-soft);
    font-size: 15.5px;
    line-height: 1.7;
    text-wrap: pretty;
  }

  /* Entry footer — mono meta left, sans 阅读原文 right */
  .entry-foot {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
    flex-wrap: wrap;
  }
  .entry-foot .meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    font-feature-settings: "tnum" 1;
  }
  .entry-foot .meta .sep {
    color: var(--border-strong);
  }
  .entry-foot .meta .src {
    color: var(--text-soft);
  }
  .entry-foot .meta .cat {
    color: var(--c, var(--accent));
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .entry-foot .meta .cat::before {
    content: "";
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--c, var(--accent));
  }
  .entry-foot .read {
    margin-left: auto;
    font-family: var(--font-sans);
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
    border-bottom: 1px solid var(--text);
    transition: color 0.15s, border-color 0.15s;
  }
  .entry-foot .read .arr {
    font-family: var(--font-mono);
    font-size: 13px;
    transition: transform 0.15s ease;
  }
  .entry-foot .read:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .entry-foot .read:hover .arr {
    transform: translate(2px, -1px);
  }

  @media (max-width: 760px) {
    .entry {
      grid-template-columns: 28px 1fr;
      column-gap: 12px;
    }
    .entry-title {
      font-size: 19px;
    }
    .entry-summary {
      font-size: 15px;
    }
    .entry-foot .read {
      margin-left: 0;
    }
  }
</style>
