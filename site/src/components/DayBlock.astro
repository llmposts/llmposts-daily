---
import type { DayGroup } from "../lib/data";
import { categoryColorVar } from "../lib/categories";
import { weekdayCn, yearOf, relativeLabel } from "../lib/dates";
import CategorySection from "./CategorySection.astro";

interface Props {
  day: DayGroup;
  /** true → 第一个日期 hero,圆点实心 */
  isFirst?: boolean;
}

const { day, isFirst = false } = Astro.props;
const rel = relativeLabel(day.key);
const showCatsNav = day.categories.length > 1;
const dayAnchor = `d-${day.key}`;
const [, monthStr, dayStr] = day.key.split("-");
const month = parseInt(monthStr, 10);
const dayOfMonth = parseInt(dayStr, 10);
// 主打分类(篇数最多的)→ 决定当天的强调色
const dominantCat = day.categories[0]?.category;
const dayAccent = dominantCat ? categoryColorVar(dominantCat) : "--link";
---

<section
  class={`day${isFirst ? " is-first" : ""}`}
  id={dayAnchor}
  style={`--day-accent: var(${dayAccent})`}
>
  <header class="day-header">
    <div class="day-year">
      <span class="yr">{yearOf(day.key)}</span>
      {rel && <span class="rel">· {rel}</span>}
    </div>
    <h1 class="day-date">
      <a href={`/daily/${day.key}/`}>
        <span class="num">{month}</span> 月 <span class="num">{dayOfMonth}</span> 日
      </a>
      <span class="wk">{weekdayCn(day.key)}</span>
    </h1>
    <div class="day-meta">共 <span class="num">{day.posts.length}</span> 篇</div>
  </header>

  <div class="day-content">
    {
      showCatsNav && (
        <nav class="day-cats" aria-label="本日分类">
          {day.categories.map((g) => (
            <a
              href={`#c-${day.key}-${g.category}`}
              style={`--cat-color: var(${categoryColorVar(g.category)})`}
            >
              <span class="dot" />
              {g.category}
              <span class="cnt">{g.posts.length}</span>
            </a>
          ))}
        </nav>
      )
    }
    {
      day.categories.map((g) => (
        <CategorySection
          group={g}
          anchorId={`c-${day.key}-${g.category}`}
        />
      ))
    }
  </div>
</section>

<style>
  .day {
    display: grid;
    grid-template-columns: var(--col-date) 1fr;
    column-gap: var(--col-gap);
    padding-top: 56px;
    position: relative;
    scroll-margin-top: 80px;
    border-top: 1px solid var(--border);
    margin-top: 56px;
  }
  .day:first-child,
  .day.is-first {
    padding-top: 40px;
    margin-top: 0;
    border-top: none;
  }

  /* 垂直 rail */
  .day::before {
    content: "";
    position: absolute;
    left: calc(var(--col-date) + var(--col-gap) / 2);
    transform: translateX(-0.5px);
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .day-header {
    grid-column: 1;
    text-align: right;
    position: relative;
  }
  /* 圆点 */
  .day-header::after {
    content: "";
    position: absolute;
    right: calc(-1 * (var(--col-gap) / 2) - 5.5px);
    top: 28px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--muted);
    box-sizing: border-box;
  }
  .day.is-first .day-header::after {
    background: var(--day-accent, var(--text));
    border-color: var(--day-accent, var(--text));
  }

  .day-year {
    font-size: 14px;
    color: var(--text-soft);
    font-weight: 500;
    margin-bottom: 8px;
  }
  .day-year .rel {
    color: var(--day-accent, var(--link));
    font-weight: 500;
    margin-left: 4px;
  }
  .day-date {
    margin: 0;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--text);
    white-space: nowrap;
  }
  .day-date a {
    color: inherit;
    text-decoration: none;
  }
  .day-date a:hover {
    color: var(--link);
  }
  .day-date .num {
    color: var(--day-accent, var(--link));
    font-feature-settings: "tnum" 1;
  }
  .day-date .wk {
    display: block;
    font-size: 14px;
    color: var(--text-soft);
    font-weight: 500;
    margin-top: 6px;
  }
  .day-meta {
    font-size: 14px;
    color: var(--text-soft);
    font-weight: 500;
    margin-top: 10px;
  }
  .day-meta .num {
    color: var(--day-accent, var(--link));
    font-weight: 600;
    font-feature-settings: "tnum" 1;
  }

  .day-content {
    grid-column: 2;
    min-width: 0;
  }

  .day-cats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0 0 28px;
  }
  .day-cats a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-soft);
    text-decoration: none;
    padding: 4px 12px 4px 10px;
    background: var(--chip-bg);
    border-radius: 999px;
    border: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .day-cats a:hover {
    border-color: var(--muted);
  }
  .day-cats .cnt {
    color: var(--muted);
    font-size: 13px;
    margin-left: 2px;
  }
  .day-cats .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cat-color, var(--muted));
    flex-shrink: 0;
  }

  @media (max-width: 760px) {
    .day {
      display: block;
      padding-top: 56px;
    }
    .day::before {
      display: none;
    }
    .day-header {
      text-align: left;
      margin-bottom: 24px;
    }
    .day-header::after {
      display: none;
    }
    .day-date {
      font-size: 26px;
    }
    .day-date .wk {
      display: inline;
      margin-top: 0;
      font-size: 14px;
    }
    .day-date .wk::before {
      content: " · ";
      color: var(--muted);
    }
  }
</style>
