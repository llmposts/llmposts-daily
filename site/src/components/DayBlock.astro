---
import type { DayGroup } from "../lib/data";
import { CATEGORY_BY_ZH, categoryColorVar } from "../lib/categories";
import { weekdayCn, yearOf, relativeLabel } from "../lib/dates";
import CategorySection from "./CategorySection.astro";

interface Props {
  day: DayGroup;
  /** true → 第一个日期 hero,圆点实心 */
  isFirst?: boolean;
}

const { day, isFirst = false } = Astro.props;
const rel = relativeLabel(day.key);
const showCatsNav = day.categories.length > 1;
const dayAnchor = `d-${day.key}`;
const [, monthStr, dayStr] = day.key.split("-");
const month = parseInt(monthStr, 10);
const dayOfMonth = parseInt(dayStr, 10);
// 主打分类(篇数最多的)→ 决定当天的强调色
const dominantCat = day.categories[0]?.category;
const dayAccent = dominantCat ? categoryColorVar(dominantCat) : "--accent";
---

<section
  class={`day${isFirst ? " is-first" : ""}`}
  id={dayAnchor}
  style={`--day-accent: var(${dayAccent})`}
>
  <header class="day-head">
    <div class="day-year">
      <span class="yr">{yearOf(day.key)}</span>
      {rel && <span class="rel"> · {rel}</span>}
    </div>
    <h2 class="day-date">
      <a href={`/daily/${day.key}/`}>
        <span class="num">{month}</span><span class="unit">月</span><span class="num">{dayOfMonth}</span><span class="unit">日</span>
      </a>
      <span class="wk">{weekdayCn(day.key)}</span>
    </h2>
    <div class="day-meta">共 <span class="n">{day.posts.length}</span> 篇</div>
  </header>

  <div class="day-content">
    {
      showCatsNav && (
        <nav class="day-cats" aria-label="本日分类">
          {day.categories.map((g) => {
            const meta = CATEGORY_BY_ZH.get(g.category);
            return (
              <a
                href={`#c-${day.key}-${g.category}`}
                style={`--c: var(${categoryColorVar(g.category)})`}
              >
                <span class="dot" />
                {meta?.short ?? g.category}
                <span class="cnt">{g.posts.length}</span>
              </a>
            );
          })}
        </nav>
      )
    }
    {
      day.categories.map((g) => (
        <CategorySection group={g} anchorId={`c-${day.key}-${g.category}`} />
      ))
    }
  </div>
</section>

<style>
  .day {
    display: grid;
    grid-template-columns: var(--col-date) 1fr;
    column-gap: var(--col-gap);
    padding-top: 56px;
    position: relative;
    scroll-margin-top: 80px;
    border-top: 1px solid var(--border);
    margin-top: 56px;
  }
  .day:first-child,
  .day.is-first {
    padding-top: 40px;
    margin-top: 0;
    border-top: none;
  }

  /* Vertical rail (timeline) */
  .day::before {
    content: "";
    position: absolute;
    left: calc(var(--col-date) + var(--col-gap) / 2);
    transform: translateX(-0.5px);
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .day-head {
    grid-column: 1;
    text-align: right;
    position: relative;
  }
  .day-head::after {
    content: "";
    position: absolute;
    right: calc(-1 * (var(--col-gap) / 2) - 5.5px);
    top: 30px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--muted);
    box-sizing: border-box;
  }
  .day.is-first .day-head::after {
    background: var(--day-accent, var(--accent));
    border-color: var(--day-accent, var(--accent));
  }

  .day-year {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 8px;
    font-feature-settings: "tnum" 1;
  }
  .day-year .rel {
    color: var(--accent);
    font-weight: 500;
  }
  .day-date {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 38px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text);
    white-space: nowrap;
  }
  .day-date a {
    color: inherit;
    text-decoration: none;
  }
  .day-date a:hover .num {
    color: var(--accent);
  }
  .day-date .num {
    color: var(--day-accent, var(--accent));
    font-feature-settings: "tnum" 1;
    transition: color 0.15s;
  }
  .day-date .unit {
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--text);
  }
  .day-date .wk {
    display: block;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--text-soft);
    font-weight: 500;
    margin-top: 8px;
    letter-spacing: 0;
  }
  .day-meta {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--muted);
    margin-top: 12px;
  }
  .day-meta .n {
    color: var(--text);
    font-weight: 600;
    font-feature-settings: "tnum" 1;
  }

  .day-content {
    grid-column: 2;
    min-width: 0;
  }

  .day-cats {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 24px;
  }
  .day-cats a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--text-soft);
    text-decoration: none;
    padding: 4px 11px 4px 9px;
    background: var(--chip-bg);
    border-radius: 999px;
    border: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .day-cats a:hover {
    border-color: var(--border-strong);
    color: var(--text);
  }
  .day-cats .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c, var(--muted));
    flex-shrink: 0;
  }
  .day-cats .cnt {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  @media (max-width: 760px) {
    .day {
      display: block;
      padding-top: 40px;
      margin-top: 40px;
    }
    .day::before {
      display: none;
    }
    .day-head {
      text-align: left;
      margin-bottom: 20px;
    }
    .day-head::after {
      display: none;
    }
    .day-date {
      font-size: 32px;
    }
    .day-date .wk {
      display: inline;
      margin-top: 0;
      font-size: 13px;
      margin-left: 10px;
    }
  }
</style>
